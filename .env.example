# ─────────────────────────────────────────────────────────
# MeuPersonal — Variáveis de ambiente centralizadas
# Copie para .env.development e preencha com valores reais.
# Execute `npm run env:sync` para gerar os arquivos de cada projeto.
# ─────────────────────────────────────────────────────────

# Supabase — https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# PostgreSQL direto — apenas para migrations Drizzle (nunca exposto no cliente)
DATABASE_URL=postgresql://postgres:your-password@db.your-project-id.supabase.co:5432/postgres

# Google Gemini — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key
