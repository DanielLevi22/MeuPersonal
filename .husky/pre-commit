branch=$(git symbolic-ref --short HEAD)

# ── Bloquear commits diretos em branches protegidas ──────────────────────────
if [ "$branch" = "main" ] || [ "$branch" = "development" ]; then
  echo ""
  echo "❌  Commits diretos em '$branch' são proibidos."
  echo "    Crie uma branch: node scripts/new-feature.js <nome>"
  echo ""
  exit 1
fi

# ── Enforcer de PRD — obrigatório em feature branches ────────────────────────
if echo "$branch" | grep -q "^feature/"; then
  feature_name="${branch#feature/}"
  prd_file="docs/PRDs/${feature_name}.md"

  # 1. PRD deve existir
  if [ ! -f "$prd_file" ]; then
    echo ""
    echo "❌  PRD obrigatório não encontrado para esta branch."
    echo ""
    echo "    Branch  : $branch"
    echo "    Esperado: $prd_file"
    echo ""
    echo "    Execute para criar a branch e o PRD corretamente:"
    echo "    → node scripts/new-feature.js ${feature_name}"
    echo ""
    echo "    Ou crie o PRD manualmente a partir do template:"
    echo "    → cp docs/PRDs/_template.md $prd_file"
    echo ""
    exit 1
  fi

  # 2. PRD não pode estar em rascunho
  if grep -q "^**Status:** draft" "$prd_file" || grep -q "Status: draft" "$prd_file"; then
    echo ""
    echo "❌  PRD ainda em rascunho. Nenhum commit permitido."
    echo ""
    echo "    Arquivo : $prd_file"
    echo ""
    echo "    Antes de codar:"
    echo "    1. Preencha as 3 perguntas obrigatórias no PRD"
    echo "    2. Mude o Status de 'draft' para 'approved'"
    echo "    3. Só então faça o commit"
    echo ""
    exit 1
  fi

  # 3. Aviso se PRD estiver como 'done' mas spec de feature não existir
  feature_spec="docs/features/${feature_name}.md"
  if grep -q "Status: done" "$prd_file" && [ ! -f "$feature_spec" ]; then
    echo ""
    echo "⚠️   PRD marcado como 'done' mas spec técnica não encontrada."
    echo ""
    echo "    Crie a spec antes de fechar a feature:"
    echo "    → cp docs/features/_template.md $feature_spec"
    echo ""
    echo "    Commit bloqueado até a spec existir."
    echo ""
    exit 1
  fi
fi

# ── Lint e TypeCheck ──────────────────────────────────────────────────────────
cd app && npm run lint && npx tsc --noEmit
cd ../web && npm run lint && npm run typecheck
