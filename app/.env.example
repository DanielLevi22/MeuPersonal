# ============================================================
# MeuPersonal — Mobile (Expo)
# Copie o arquivo correspondente ao ambiente que quiser usar:
#   Local  (Docker): copie os valores da seção LOCAL abaixo
#   Dev    (cloud):  preencha com as credenciais do projeto dev
#   Prod   (cloud):  preencha com as credenciais do projeto prod
# ============================================================

# ------ LOCAL (Supabase CLI via Docker — supabase start) ------
# EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRFA0NiK7kyqd70QpgXTQDGgr47UlRX5nf9wDAnCx88
# EXPO_PUBLIC_APP_ENV=local

# ------ DEV / PROD (Supabase cloud) ------
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Gemini AI — https://aistudio.google.com/app/apikey
EXPO_PUBLIC_GEMINI_API_KEY=your-gemini-api-key

EXPO_PUBLIC_APP_ENV=development
