{
  "$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "ignore": [
      "app/drizzle/migrations/meta/**",
      "**/node_modules/**"
    ]
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "overrides": [
    {
      "includes": ["**/globals.css"],
      "linter": { "enabled": false },
      "formatter": { "enabled": false }
    },
    {
      "includes": ["app/**/*"],
      "linter": {
        "rules": {
          "style": {
            "useImportType": "off"
          }
        }
      },
      "javascript": {
        "formatter": {
          "quoteStyle": "single",
          "trailingCommas": "es5",
          "semicolons": "always",
          "arrowParentheses": "always"
        }
      }
    },
    {
      "includes": ["web/**/*"],
      "linter": {
        "rules": {
          "a11y": {
            "noSvgWithoutTitle": "off",
            "useButtonType": "off",
            "noLabelWithoutControl": "off",
            "useKeyWithClickEvents": "off",
            "noStaticElementInteractions": "off",
            "useSemanticElements": "off"
          },
          "suspicious": {
            "noUnknownAtRules": "off",
            "noExplicitAny": "off",
            "noArrayIndexKey": "off"
          },
          "correctness": {
            "useExhaustiveDependencies": "off"
          }
        },
        "domains": {
          "next": "recommended",
          "react": "recommended"
        }
      }
    }
  ]
}
