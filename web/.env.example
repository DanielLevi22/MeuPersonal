# ============================================================
# MeuPersonal — Web (Next.js)
# Copie o arquivo correspondente ao ambiente que quiser usar:
#   Local  (Docker): copie os valores da seção LOCAL abaixo → salve como .env.local
#   Dev    (cloud):  preencha com as credenciais do projeto dev → salve como .env
#   Prod   (cloud):  configurar via Vercel Environment Variables
# ============================================================

# ------ LOCAL (Supabase CLI via Docker — supabase start) ------
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRFA0NiK7kyqd70QpgXTQDGgr47UlRX5nf9wDAnCx88
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hj04zWl196z2-SBc0
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# ------ DEV / PROD (Supabase cloud) ------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# service_role — nunca expor no cliente, apenas server-side
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# PostgreSQL direto — apenas para migrations Drizzle
# Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres:your-password@db.your-project-id.supabase.co:5432/postgres

# Anthropic — AI Coach (server-side apenas)
# console.anthropic.com → API Keys
ANTHROPIC_API_KEY=your-anthropic-api-key
